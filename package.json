{
  "name": "markov-text-predictor",
  "version": "1.0.0",
  "description": "Modèle de Markov appliqué aux textes pour la prédiction de saisie au clavier",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "lint": "biome lint ./src",
